# Copy this file to .env and fill in your values
# Never commit .env to git

# Django
DJANGO_SECRET_KEY=your-secret-key-here-generate-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://xtudio:xtudio@localhost:5432/xtudio

# Email (for development use console backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@xtudio.dev

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Anthropic (not used in Phase 1 — set for Phase 2)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Workspace
WORKSPACE_ROOT=workspace
